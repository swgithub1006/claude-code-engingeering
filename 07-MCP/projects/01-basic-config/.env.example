# MCP 服务器环境变量配置
# 复制此文件为 .env 并填入你的值
# 注意：不要将 .env 文件提交到版本控制！确保 .gitignore 包含 .env

# ============ 需要 API Key 的服务 ============

# GitHub Token（必需：GitHub MCP）
# 获取地址：GitHub → Settings → Developer settings → Personal access tokens → Fine-grained tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Notion API Key（必需：Notion MCP）
# 获取地址：https://www.notion.so/profile/integrations → 创建 Internal Integration
# 注意：还需要在 Notion 页面的 Connections 里添加你的 Integration
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxx

# 数据库连接（必需：Database MCP）
# 格式：postgresql://用户名:密码@主机:端口/数据库名
# 建议使用只读账户，防止 Claude 误操作
DATABASE_URL=postgresql://readonly:password@localhost:5432/mydb

# ============ 无需 API Key 的服务 ============
# Context7、Fetch、Filesystem、Memory 均无需 API Key，开箱即用
